NODE_ENV=development
PORT=5000
HOST=0.0.0.0

PUBLIC_API_URL=http://127.0.0.1:5000
PUBLIC_WEB_URL=http://127.0.0.1:5174
PUBLIC_DESKTOP_PROTOCOL=reelms

CORS_ORIGINS=http://127.0.0.1:3105,http://127.0.0.1:5174,http://localhost:5174

JWT_SECRET=dev-only-change-this-secret
JSON_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=300
RATE_LIMIT_API_MAX=5000
RATE_LIMIT_DISABLED=false

# Local beta: json. Production targets: postgres or supabase.
REELMS_STORAGE_DRIVER=json
REELMS_DATA_DIR=./data
DATABASE_URL=
REDIS_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

S3_BUCKET=
S3_PUBLIC_BASE_URL=
AWS_REGION=eu-central-1

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/callback/google

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback/spotify

OPENAI_API_KEY=
