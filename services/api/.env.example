NODE_ENV=development
PORT=5000
HOST=0.0.0.0

PUBLIC_API_URL=http://127.0.0.1:5000
PUBLIC_WEB_URL=http://127.0.0.1:5174
PUBLIC_DESKTOP_PROTOCOL=reelms

CORS_ORIGINS=http://127.0.0.1:3105,http://127.0.0.1:5174,http://localhost:5174

JWT_SECRET=dev-only-change-this-secret
JSON_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=300
RATE_LIMIT_API_MAX=5000
RATE_LIMIT_DISABLED=false

# Local beta: json. Production targets: postgres or supabase.
REELMS_STORAGE_DRIVER=json
REELMS_DATA_DIR=./data
REELMS_COMMUNITY_ADMIN_UIDS=
REELMS_COMMUNITY_ADMIN_EMAILS=
REELMS_COMMUNITY_ADMIN_USERNAMES=
REELMS_ALLOW_UNVERIFIED_ADMIN_IDENTIFIERS=false
DATABASE_URL=
REDIS_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Open beta auth. Keep false during closed migration; turn true after Resend/domain is ready.
REELMS_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_PROVIDER=console
RESEND_API_KEY=
MAIL_FROM_EMAIL=Reelms <noreply@your-domain.com>
AUTH_TOKEN_TTL_MS=86400000
PASSWORD_RESET_TTL_MS=1800000

# S3 uploads. Leave empty locally; set all four in AWS/prod.
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_UPLOAD_PREFIX=reelms-uploads
S3_MAX_UPLOAD_BYTES=26214400
S3_PRESIGN_TTL_SECONDS=900
AWS_REGION=eu-central-1

# WebRTC ICE. STUN works by default; add TURN before open/public beta.
STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun.cloudflare.com:3478
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

LOG_LEVEL=info
LOG_FORMAT=pretty
SENTRY_DSN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5000/callback/google

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/callback/spotify

OPENAI_API_KEY=
FEEDBACK_FROM_EMAIL=
FEEDBACK_TO_EMAIL=
