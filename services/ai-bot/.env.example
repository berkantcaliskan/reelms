# Reelms API adresi
API_URL=http://127.0.0.1:5000

# API'deki REELMS_AI_BOT_SECRET ile aynı olmalı
BOT_SECRET=dev-only-bot-secret-change-me

# OpenAI API anahtarı (zorunlu)
OPENAI_API_KEY=sk-...

# Kullanılacak model (varsayılan: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Günlük digest saati (0-23, varsayılan: 9 = sabah 9)
DAILY_DIGEST_HOUR=9
