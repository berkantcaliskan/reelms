# Reelms web development
VITE_API_BASE_URL=http://127.0.0.1:5000
VITE_BACKEND_URL=http://127.0.0.1:5000

# Optional: public Windows setup link.
# Leave empty while there is no public release; the app will open #/download instead of a broken placeholder.
# GitHub Releases example:
# VITE_WINDOWS_DOWNLOAD_URL=https://github.com/<owner>/<repo>/releases/latest/download/Reelms-Setup.exe
# CloudFront example:
# VITE_WINDOWS_DOWNLOAD_URL=https://download.reelms.io/win/Reelms-Setup.exe

VITE_WINDOWS_DOWNLOAD_URL=
VITE_DESKTOP_RELEASE_CHANNEL=Web Beta
